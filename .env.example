# QYNE v1 — Environment Variables
# Copy to .env and fill in values.

# PostgreSQL (superuser, only for init script)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# Directus
DIRECTUS_SECRET=CHANGE_ME_RANDOM_STRING
DIRECTUS_ADMIN_EMAIL=admin@qyne.dev
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME
DIRECTUS_TOKEN=CHANGE_ME_API_TOKEN

# RustFS
RUSTFS_USER=qyne
RUSTFS_PASSWORD=CHANGE_ME

# LLM Keys (at least one required)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
VOYAGE_API_KEY=

# n8n
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME

# WhatsApp (optional)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_URL=
# WHATSAPP_VERIFY_TOKEN=
